{
  "name": "Fiorielementsfeatures",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9.9.1"
  },
  "devDependencies": {
    "@cap-js/cds-typer": ">=0.1",
    "@cap-js/cds-types": "^0.16.0",
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "@types/node": "^24.0.0",
    "tsx": "^4",
    "typescript": "^6.0.0",
    "cds-plugin-ui5": "^0.17.0",
    "rimraf": "^5.0.5",
    "mbt": "^1.2.49"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-testmodule": "cds watch --open com.subbu.testmodule/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy Fiorielementsfeatures --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "private": true,
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/testmodule"
  ]
}
